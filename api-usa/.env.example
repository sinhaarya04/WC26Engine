# Example environment configuration.
# Copy to .env.development or .env.production and fill in real values.
# NEVER commit real credentials to git.

NODE_ENV=development

# Server
PORT=3050
API_URL=http://localhost:3050
FRONTEND_URL=http://localhost:3050

# Database
# For production with auth: mongodb://username:password@host:port/dbname?authSource=admin
MONGODB_URL=mongodb://localhost:27017/worldcup2026

# Security — generate strong random keys for production
JWT_SECRET=replace_me_with_a_long_random_string
SECRET=replace_me_with_a_long_random_string
ACCESSCODEDEV=replace_me_with_an_admin_access_code

# Logging (debug, info, warn, error)
LOG_LEVEL=debug

# Swagger Documentation (true/false; always enabled in development)
ENABLE_SWAGGER=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX=300

# CORS (use * for development, specific origins for production)
# In non-production, http://localhost:5173 (Vite dev server) and
# http://localhost:3000 are added automatically by getCorsOrigins() — you
# don't have to list them here.
CORS_ORIGINS=*

# Admin seed — credentials for `npm run seed:admin`.
# Set these before running the seed; never commit real values.
ADMIN_EMAIL=
ADMIN_PASSWORD=
