# tigress-picks-prototype — example env config.
# Copy to .env.local for dev (gitignored by Vite convention) or set the same
# variables in your hosting platform's project settings for production.
# NEVER commit real values for any var named *_SECRET / *_KEY / *_TOKEN.

# Base URL of the api-usa backend. No trailing slash.
# Dev:  http://localhost:3050
# Prod: https://your-api.example.com   (Render/Railway/Vercel API URL)
VITE_API_BASE_URL=http://localhost:3050
